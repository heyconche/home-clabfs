# ── Shared no-cache policy ─────────────────────────────────────────────────────
(no_cache) {
    header {
        Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Pragma "no-cache"
        Expires "0"
    }
}

# ── Dashboard principal ────────────────────────────────────────────────────────
conche.com.br {
    import no_cache

    # Login e logout são públicos — sem forward_auth
    handle /login* {
        reverse_proxy auth:5001
    }
    handle /logout* {
        reverse_proxy auth:5001
    }

    # Tudo exceto /login* e /logout* é protegido
    @needsAuth not path /login* /logout*
    forward_auth @needsAuth auth:5001 {
        uri /verify
    }

    handle /stats/* {
        uri strip_prefix /stats
        reverse_proxy glances:61208
    }
    handle {
        reverse_proxy dashboard:80
    }
}

# ── Filebrowser ────────────────────────────────────────────────────────────────
nfs.conche.com.br {
    import no_cache
    header {
        +Link "</manifest.webmanifest>; rel=manifest"
        +Link "</apple-touch-icon.png>; rel=\"apple-touch-icon\""
    }

    handle /apple-touch-icon.png {
        root * /srv/static/nfs
        file_server
    }
    handle /manifest.webmanifest {
        root * /srv/static/nfs
        file_server
    }

    forward_auth auth:5001 {
        uri /verify
    }
    reverse_proxy filebrowser:80 {
        header_up X-Auth-User "admin"
    }
}

# ── Vaultwarden ────────────────────────────────────────────────────────────────
cofre.conche.com.br {
    import no_cache
    reverse_proxy vaultwarden:80
}

# ── Ghost ──────────────────────────────────────────────────────────────────────
soul.conche.com.br {
    import no_cache

    forward_auth auth:5001 {
        uri /verify
    }
    reverse_proxy ghost:2368
}

# ── Immich ─────────────────────────────────────────────────────────────────────
# forward_auth removido — Immich tem autenticação própria (Bearer token)
fotos.conche.com.br {
    import no_cache
    reverse_proxy immich-server:2283
}

# ── Food (dieta e mercado) ────────────────────────────────────────────────────
food.conche.com.br {
    import no_cache

    forward_auth auth:5001 {
        uri /verify
    }
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy auth:5001
    }
    handle {
        reverse_proxy food:80
    }
}

