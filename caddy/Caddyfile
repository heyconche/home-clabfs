# InfraDash (custo multi-cloud)
dash.conche.com.br {
    reverse_proxy infradash:5000
}

# Dashboard principal
conche.com.br {
    # Proxy da API de stats (Glances) — acessível só internamente via este path
    handle /stats/* {
        uri strip_prefix /stats
        reverse_proxy glances:61208
    }

    # Dashboard
    handle {
        reverse_proxy dashboard:80
    }
}

# Filebrowser
nfs.conche.com.br {
    reverse_proxy filebrowser:80
}

# Vaultwarden
cofre.conche.com.br {
    reverse_proxy vaultwarden:80
}

# Ghost (blog)
soul.conche.com.br {
    reverse_proxy ghost:2368
}

# Immich (fotos)
fotos.conche.com.br {
    reverse_proxy immich-server:2283
}
