# Copy to .env and fill in the values
# NEVER commit the .env file

# в”Ђв”Ђ Auth (SSO) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Gere o secret com: openssl rand -hex 32
AUTH_SECRET=gere_com_openssl_rand_-hex_32
AUTH_USERNAME=admin
# Gere o hash com: docker run --rm python:3.12-slim python3 -c \
#   "import bcrypt; print(bcrypt.hashpw(b'SUA_SENHA', bcrypt.gensalt()).decode())"
AUTH_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

VAULTWARDEN_ADMIN_TOKEN=generate_with_openssl_rand_-base64_48

IMMICH_DB_PASSWORD=strong_password_here

# в”Ђв”Ђ InfraDash вЂ” Cloud credentials в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

# AWS
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_DEFAULT_REGION=us-east-1

# GCP (credentials file mounted separately as infradash/credentials/gcp.json)
GCP_PROJECT_ID=your_project_id
GCP_CREDENTIALS_PATH=/app/credentials/gcp.json
GCP_BIGQUERY_TABLE=  # project.dataset.table вЂ” leave empty until BigQuery export is set up

# OCI (key file mounted separately as infradash/credentials/oci.pem)
OCI_USER_OCID=ocid1.user.oc1..xxx
OCI_FINGERPRINT=xx:xx:xx:xx
OCI_TENANCY_OCID=ocid1.tenancy.oc1..xxx
OCI_REGION=sa-saopaulo-1
OCI_KEY_FILE=/app/credentials/oci.pem

